<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Advanced Iframe Viewer</title>

<style>
body{
    font-family: Arial, sans-serif;
    background-color:#f0f8ff;
    text-align:center;
}

h1{
    color:#2c3e50;
}

.menu a{
    text-decoration:none;
    background:#3498db;
    color:white;
    padding:8px 15px;
    margin:5px;
    display:inline-block;
    border-radius:6px;
}

.menu a:hover{
    background:#1abc9c;
}

iframe{
    border:2px solid #333;
    border-radius:10px;
    box-shadow:2px 2px 10px gray;
}

.dashboard{
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
    gap:20px;
}

.box{
    width:420px;
}
</style>

</head>

<body>

<h1>🌐 Smart Iframe Browser</h1>
<p>Click a website to load it in the main viewer.</p>

<div class="menu">
<a href="https://www.wikipedia.org" target="mainFrame">Wikipedia</a>
<a href="https://www.youtube.com" target="mainFrame">YouTube</a>
<a href="https://www.google.com/maps" target="mainFrame">Google Maps</a>
<a href="https://www.example.com" target="mainFrame">Example</a>
<a href="https://www.bbc.com" target="mainFrame">BBC News</a>
</div>

<br>

<!-- Main iframe -->
<iframe name="mainFrame" src="https://www.wikipedia.org" width="1000" height="500"></iframe>

<hr>

<h2>Dashboard View</h2>

<div class="dashboard">

<div class="box">
<h3>Wikipedia</h3>
<iframe src="https://www.wikipedia.org" width="400" height="250"></iframe>
</div>

<div class="box">
<h3>YouTube</h3>
<iframe src="https://www.youtube.com" width="400" height="250"></iframe>
</div>

<div class="box">
<h3>Google Maps</h3>
<iframe src="https://www.google.com/maps" width="400" height="250"></iframe>
</div>

<div class="box">
<h3>BBC News</h3>
<iframe src="https://www.bbc.com" width="400" height="250"></iframe>
</div>

</div>

<hr>

<footer>
<p>Mini Browser Dashboard Project</p>
</footer>

</body>
</html>
